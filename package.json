{
  "name": "react-native-turbo-toast",
  "version": "1.0.1",
  "description": "High-performance toast notifications for React Native with TurboModules",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "sideEffects": [
    "./src/styles.ts",
    "./src/index.tsx"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "jest",
    "prepare": "bob build",
    "prepublishOnly": "bun run typecheck && bunx jest --ci && bob build",
    "release": "release-it",
    "example": "cd example && bun run"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "web",
    "toast",
    "snackbar",
    "notification",
    "edge",
    "fabric",
    "turbomodule",
    "new-architecture",
    "jsi",
    "typescript"
  ],
  "author": "Anivar Aravind <ping@anivar.net>",
  "license": "MIT",
  "homepage": "https://github.com/openslm-ai/react-native-turbo-toast",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openslm-ai/react-native-turbo-toast.git"
  },
  "bugs": {
    "url": "https://github.com/openslm-ai/react-native-turbo-toast/issues"
  },
  "funding": "https://github.com/sponsors/anivar",
  "packageManager": "bun@1.3.13",
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-native": ">=0.81.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@react-native/babel-preset": "^0.81.0",
    "@react-native/codegen": "^0.81.0",
    "@react-native/typescript-config": "^0.81.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.0.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "react": "^19.0.0",
    "react-native": "^0.81.0",
    "react-native-builder-bob": "^0.40.0",
    "release-it": "^17.0.0",
    "typescript": "^5.9.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  },
  "codegenConfig": {
    "name": "RNTurboToastSpec",
    "type": "all",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.turbo.toast"
    }
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "react-native-turbo-toast.podspec",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ]
}
